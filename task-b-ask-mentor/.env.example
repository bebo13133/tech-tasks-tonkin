# Копирай този файл като .env.local и попълни своя ключ:
#   cp .env.example .env.local   (Windows PowerShell: Copy-Item .env.example .env.local)

# Anthropic API ключ — вземи от https://console.anthropic.com/
# .env.local НЕ се commit-ва (виж .gitignore) — ключът остава само локално.
ANTHROPIC_API_KEY=

# Опционално: override на модела. Default е claude-sonnet-4-6 (както иска заданието).
# ANTHROPIC_MODEL=claude-sonnet-4-6
